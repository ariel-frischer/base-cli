package main

import (
	"os"

[% if .Config -%]
	"[% .ModulePath %]/internal/config"
[% end -%]
	"[% .ModulePath %]/internal/version"
	"github.com/fatih/color"
	"github.com/spf13/cobra"
)

var rootCmd = &cobra.Command{
	Use:     "[% .BinaryName %]",
	Short:   "[% .Description %]",
	Version: version.Version,
}

[%- if .Config %]
var configPathOverride string

[%- end %]
func init() {
	// Disable colors when not writing to a terminal.
	if fi, err := os.Stdout.Stat(); err == nil {
		if fi.Mode()&os.ModeCharDevice == 0 {
			color.NoColor = true
		}
	}

	var noColor bool
	rootCmd.PersistentFlags().BoolVar(&noColor, "no-color", false, "disable colored output")
[%- if .Config %]
	rootCmd.PersistentFlags().StringVar(&configPathOverride, "config", "", "config file path (default $[% .EnvPrefix %]_CONFIG or ~/.config/[% .BinaryName %]/config.yaml)")
[%- end %]
	rootCmd.PersistentPreRun = func(cmd *cobra.Command, args []string) {
		if noColor {
			color.NoColor = true
		}
	}

	rootCmd.SetHelpFunc(colorizedHelp)

	rootCmd.AddCommand(versionCmd)
[%- if .Config %]
	rootCmd.AddCommand(configCmd)
[%- end %]
}

[%- if .Config %]
func selectedConfigPath() string {
	return config.Path(configPathOverride)
}
[%- end %]
