version: 2

before:
  hooks:
    - go mod tidy

builds:
  - main: ./cmd/[% .BinaryName %]/
    binary: [% .BinaryName %]
    ldflags:
      - -s -w
      - -X [% .ModulePath %]/internal/version.Version={{.Version}}
      - -X [% .ModulePath %]/internal/version.Commit={{.ShortCommit}}
      - -X [% .ModulePath %]/internal/version.BuildDate={{.Date}}
    env:
      - CGO_ENABLED=0
    goos:
      - linux
      - darwin
      - windows
    goarch:
      - amd64
      - arm64

archives:
  - format: tar.gz
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - README.md
[% if ne .License "none" %]      - LICENSE
[% end %]    format_overrides:
      - goos: windows
        format: zip

checksum:
  name_template: checksums.txt

changelog:
  disable: true

release:
[% if .CIGitHub %]  github:
    owner: [% .GitUser %]
    name: [% .ProjectName %]
[% end %][% if .CIGitLab %]  gitlab:
    owner: [% .GitUser %]
    name: [% .ProjectName %]
[% end %]  mode: replace
